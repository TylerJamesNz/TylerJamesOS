# Copy to .env.local. The LOCAL block below points at the local Supabase stack
# served on tylerbatchelor.local (requires "127.0.0.1 tylerbatchelor.local" in
# /etc/hosts; see README). The CLOUD block points at the cloud Supabase project
# and is what GitHub Actions injects at build time via repo secrets.

# --- LOCAL (default) ---
VITE_SUPABASE_URL=https://tylerbatchelor.local:4443/api
VITE_SUPABASE_ANON_KEY=<publishable key from `supabase status`>

# --- CLOUD (uncomment to point dev at the cloud project) ---
# VITE_SUPABASE_URL=https://<project-ref>.supabase.co
# VITE_SUPABASE_ANON_KEY=<publishable-anon-key>
