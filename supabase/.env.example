# Copy to supabase/.env and fill in the Client ID and Client Secret from the
# `Tyler James OS` OAuth client in Google Cloud Console. Local GoTrue reads
# these via `env(...)` interpolation in supabase/config.toml.
#
# This file is gitignored. The cloud Supabase project gets these via the
# Supabase dashboard, not this file.

GOOGLE_OAUTH_CLIENT_ID=<client id>
GOOGLE_OAUTH_CLIENT_SECRET=<client secret>
